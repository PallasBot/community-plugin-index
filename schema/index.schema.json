{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/PallasBot/community-plugin-index/schema/index.schema.json",
  "title": "Pallas community plugin index",
  "type": "object",
  "required": ["version", "plugins"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      }
    }
  },
  "$defs": {
    "pluginEntry": {
      "type": "object",
      "required": ["id", "repository"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "repository": {
          "type": "string",
          "pattern": "^(https://|git@)"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "min_pallas_version": {
          "type": "string"
        }
      }
    }
  }
}
